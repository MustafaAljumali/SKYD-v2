# ── SKYD Backend Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your real values

# ── Project ──────────────────────────────────────────────────────────────────
PROJECT_NAME="SKYD — Smart Field Intelligence Platform"
VERSION="2.0.0"
DEBUG=false

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-use-openssl-rand-hex-32
# Comma-separated allowed origins (set to your frontend domain in production)
ALLOWED_ORIGINS=["http://localhost:3000","https://skyd.iq"]

# ── PostgreSQL Database ───────────────────────────────────────────────────────
POSTGRES_USER=skyd
POSTGRES_PASSWORD=skyd_secret_change_me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=skyd_db

# ── YOLOv8 Crop Disease Model ─────────────────────────────────────────────────
YOLO_MODEL_PATH=models/skyd_crop_disease_v8.pt
YOLO_CONFIDENCE_THRESHOLD=0.45
YOLO_IOU_THRESHOLD=0.45
MAX_IMAGE_SIZE_MB=10

# ── Satellite — Copernicus/Sentinel-2 (SERVER-SIDE ONLY) ─────────────────────
# Register at: https://dataspace.copernicus.eu/
# NEVER expose these to the frontend
COPERNICUS_CLIENT_ID=your_copernicus_client_id_here
COPERNICUS_CLIENT_SECRET=your_copernicus_client_secret_here

# ── AI Advice — Google Gemini (SERVER-SIDE ONLY) ──────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── WebSocket ─────────────────────────────────────────────────────────────────
WS_HEARTBEAT_INTERVAL=30

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/skyd.log

# ── Uvicorn ───────────────────────────────────────────────────────────────────
WORKERS=4
