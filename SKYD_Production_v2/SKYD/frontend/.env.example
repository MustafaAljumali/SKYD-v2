# ── SKYD Frontend Environment Variables ─────────────────────────────────────
# Copy to .env and fill in real values. ALL values below are REQUIRED for production.

# ── API Backend ──────────────────────────────────────────────────────────────
# FastAPI backend URL (no trailing slash). REQUIRED for production.
# If missing, defaults to http://localhost:8000 (development only).
VITE_API_URL=https://api.skyd.farm/v1

# Legacy/alternative key (used if VITE_API_URL is not set)
VITE_SKYD_API_URL=http://localhost:8000

# The URL where this frontend is hosted (for self-referential links)
APP_URL=http://localhost:3000

# Backend URL for Express proxy (server.ts)
SKYD_BACKEND_URL=http://localhost:8000

# ── Firebase Configuration ────────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Your Apps → Web App
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── OpenWeatherMap (Frontend weather API) ─────────────────────────────────────
# Register at https://openweathermap.org/api — Free tier works (60 calls/min).
# Primary key (checked first):
VITE_OPENWEATHER_API_KEY=
# Legacy/alternative keys (checked as fallbacks):
# VITE_OPENWEATHERMAP_API_KEY=
# VITE_OWM_API_KEY=

# ── Map Tiles (optional — if using custom tile provider) ──────────────────────
# VITE_MAP_TILE_URL=https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}

# ── Feature Flags ─────────────────────────────────────────────────────────────
# MUST be "false" in production. When "true", enables manual telemetry injection
# and other development-only tools.
VITE_ENABLE_MOCK_DATA=false

# ── NOTE: The following keys MUST stay in backend .env ONLY ──────────────────
# COPERNICUS_CLIENT_ID — Sentinel-2 satellite API (backend only)
# COPERNICUS_CLIENT_SECRET — (backend only)
# GEMINI_API_KEY — AI advice/diagnosis (backend only)
